source_env_if_exists .envrc.local

if [ -z "${GBV_VEYR_TOOLCHAIN_TARBALL:-}" ]; then
  # The pinned Veyr release is private while the language repository remains
  # private. Fetch it with the user's authenticated GitHub CLI and verify it
  # before Nix sees only the archive path (never the GitHub credential).
  toolchain_tarball="$(
    nix shell nixpkgs#gh nixpkgs#coreutils nixpkgs#gawk \
      --command bash "$PWD/scripts/fetch-veyr-toolchain.sh"
  )" || return $?
  export GBV_VEYR_TOOLCHAIN_TARBALL="$toolchain_tarball"
fi

use flake . --impure
