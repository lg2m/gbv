test "rejects_mode_not_supported_by_physical_profile" {
  match select_hardware_profile("dmg-c", "cgb", CartridgeMode.dmg) {
    Ok(_) => {
      expect.fail("incompatible model and mode were accepted")
    }
    Err(reason) => {
