use core.testing.expect

test "selects_dmg_c_native_for_dmg_software" {
  match select_hardware_profile("dmg-c", "dmg", CartridgeMode.dmg) {
    Ok(profile) => {
      expect.equal(profile.model(), HardwareModel.dmg)
      expect.equal(profile.revision(), HardwareRevision.dmg_c)
      expect.equal(profile.mode(), OperatingMode.dmg)
      expect.equal(profile.stable_id(), "dmg-c/dmg")
    }
    Err(_) => {
      expect.fail("valid DMG-C profile was rejected")
    }
  }
}

test "selects_cgb_d_native_for_cgb_software" {
  match select_hardware_profile("cgb-d", "cgb", CartridgeMode.cgb_only) {
    Ok(profile) => {
      expect.equal(profile.model(), HardwareModel.cgb)
      expect.equal(profile.revision(), HardwareRevision.cgb_d)
      expect.equal(profile.mode(), OperatingMode.cgb)
      expect.equal(profile.stable_id(), "cgb-d/cgb")
    }
    Err(_) => {
      expect.fail("valid CGB-D profile was rejected")
    }
  }
}

test "selects_cgb_d_compatibility_for_dmg_software" {
  match select_hardware_profile("cgb-d", "dmg-compat", CartridgeMode.dmg) {
    Ok(profile) => {
      expect.equal(profile.model(), HardwareModel.cgb)
      expect.equal(profile.revision(), HardwareRevision.cgb_d)
      expect.equal(profile.mode(), OperatingMode.cgb_dmg_compat)
      expect.equal(profile.stable_id(), "cgb-d/dmg-compat")
    }
    Err(_) => {
      expect.fail("valid CGB-D compatibility profile was rejected")
    }
  }
}

test "accepts_dual_mode_software_on_dmg_c" {
  expect.ok(select_hardware_profile("dmg-c", "dmg", CartridgeMode.cgb_compatible))
}

test "accepts_dual_mode_software_in_native_cgb_mode" {
  expect.ok(select_hardware_profile("cgb-d", "cgb", CartridgeMode.cgb_compatible))
}

test "rejects_omitted_hardware_profile" {
  match select_hardware_profile("", "dmg", CartridgeMode.dmg) {
    Ok(_) => {
      expect.fail("omitted profile was accepted")
    }
    Err(reason) => {
      expect.equal(reason, ProfileSelectionError.missing_profile)
    }
  }
}

test "rejects_unknown_hardware_profile" {
  match select_hardware_profile("generic", "dmg", CartridgeMode.dmg) {
