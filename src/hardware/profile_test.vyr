test "selects_dmg_c_post_boot_contract" {
  match select_hardware_profile("dmg-c", "dmg", CartridgeMode.dmg) {
    Ok(profile) => {
      let inputs = post_boot_inputs(
        0x00 as uint8,
        false,
        0x00 as uint8,
        CgbCompatibilityBootInput.none_held
      )
      let contract = post_boot_contract(profile, inputs)
      let cpu = contract.cpu_registers()
      expect.equal(contract.program_counter(), 0x0100 as uint16)
      expect.equal(contract.stack_pointer(), 0xfffe as uint16)
      expect.equal(contract.is_boot_rom_mapped(), false)
      expect.equal(cpu.af(), 0x0180 as uint16)
      expect.equal(cpu.bc(), 0x0013 as uint16)
      expect.equal(cpu.de(), 0x00d8 as uint16)
      expect.equal(cpu.hl(), 0x014d as uint16)
      expect.equal(contract.provenance(), PostBootStateProvenance.pan_docs_dmg_handoff)
    }
    Err(_) => {
      expect.fail("valid DMG-C profile was rejected")
    }
  }
}

test "derives_dmg_c_flags_from_nonzero_header_checksum" {
  match select_hardware_profile("dmg-c", "dmg", CartridgeMode.dmg) {
    Ok(profile) => {
      let inputs = post_boot_inputs(
        0x01 as uint8,
        false,
        0x00 as uint8,
        CgbCompatibilityBootInput.none_held
      )
      expect.equal(
        post_boot_contract(profile, inputs).cpu_registers().af(),
        0x01b0 as uint16
      )
    }
    Err(_) => {
      expect.fail("valid DMG-C profile was rejected")
    }
  }
}

test "selects_cgb_d_native_post_boot_state" {
  match select_hardware_profile("cgb-d", "cgb", CartridgeMode.cgb_only) {
    Ok(profile) => {
      let inputs = post_boot_inputs(
        0x00 as uint8,
        false,
        0x00 as uint8,
        CgbCompatibilityBootInput.none_held
      )
      let contract = post_boot_contract(profile, inputs)
      let cpu = contract.cpu_registers()
      expect.equal(cpu.af(), 0x1180 as uint16)
      expect.equal(cpu.bc(), 0x0000 as uint16)
      expect.equal(cpu.de(), 0xff56 as uint16)
      expect.equal(cpu.hl(), 0x000d as uint16)
      expect.equal(contract.provenance(), PostBootStateProvenance.pan_docs_cgb_handoff)
    }
    Err(_) => {
      expect.fail("valid CGB-D profile was rejected")
    }
  }
}

test "selects_cgb_d_compatibility_post_boot_state" {
  match select_hardware_profile("cgb-d", "dmg-compat", CartridgeMode.dmg) {
    Ok(profile) => {
      let inputs = post_boot_inputs(
        0x00 as uint8,
        true,
        0x43 as uint8,
        CgbCompatibilityBootInput.none_held
      )
      let contract = post_boot_contract(profile, inputs)
      let cpu = contract.cpu_registers()
      expect.equal(cpu.af(), 0x1180 as uint16)
      expect.equal(cpu.bc(), 0x4300 as uint16)
      expect.equal(cpu.de(), 0x0008 as uint16)
      expect.equal(cpu.hl(), 0x991a as uint16)
      expect.equal(
        contract.provenance(),
        PostBootStateProvenance.pan_docs_cgb_compat_handoff
      )
      expect.equal(
        contract.cgb_compatibility_boot_input(),
        CgbCompatibilityBootInput.none_held
      )
    }
    Err(_) => {
      expect.fail("valid CGB-D compatibility profile was rejected")
    }
  }
}

test "derives_cgb_compatibility_state_for_non_nintendo_header" {
  match select_hardware_profile("cgb-d", "dmg-compat", CartridgeMode.dmg) {
    Ok(profile) => {
      let inputs = post_boot_inputs(
        0x00 as uint8,
        false,
        0x43 as uint8,
        CgbCompatibilityBootInput.none_held
      )
      let cpu = post_boot_contract(profile, inputs).cpu_registers()
      expect.equal(cpu.bc(), 0x0000 as uint16)
      expect.equal(cpu.hl(), 0x007c as uint16)
    }
    Err(_) => {
      expect.fail("valid CGB-D compatibility profile was rejected")
    }
  }
}

test "keeps_boot_policy_separate_from_hardware_profile" {
  match select_hardware_profile("dmg-c", "dmg", CartridgeMode.dmg) {
    Ok(profile) => {
      let booted = run_configuration(profile, BootPolicy.user_boot_rom)
      let post_boot = run_configuration(profile, BootPolicy.post_boot_start)
      expect.equal(booted.hardware_profile(), post_boot.hardware_profile())
      expect.equal(booted.boot_policy(), BootPolicy.user_boot_rom)
      expect.equal(post_boot.boot_policy(), BootPolicy.post_boot_start)
    }
    Err(_) => {
      expect.fail("valid DMG-C profile was rejected")
    }
  }
}

test "starts_user_boot_rom_at_power_on_entry" {
  match select_hardware_profile("dmg-c", "dmg", CartridgeMode.dmg) {
    Ok(profile) => {
      let contract = boot_rom_contract(profile)
      expect.equal(contract.program_counter(), 0x0000 as uint16)
      expect.equal(contract.is_boot_rom_mapped(), true)
      expect.equal(contract.layout(), BootRomLayout.dmg_256)
    }
    Err(_) => {
      expect.fail("valid DMG-C profile was rejected")
    }
  }
}
