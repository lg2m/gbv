  ) {
    Ok(_) => {
      expect.fail("incompatible model and revision were accepted")
    }
    Err(reason) => {
      expect.equal(reason, ProfileSelectionError.incompatible_model_revision)
    }
  }
}

test "rejects_dmg_revision_on_cgb_model" {
  match hardware_profile(
    HardwareModel.cgb,
